{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "simalytics-api",
	"main": "src/index.ts",
	"compatibility_date": "2026-04-20",
	"compatibility_flags": ["nodejs_compat"],
	"routes": [
		{ "pattern": "api.simalytics.kyter.com", "custom_domain": true }
	],
	"observability": {
		"enabled": true
	}
}
